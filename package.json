{
  "name": "n8n-nodes-gateio",
  "version": "1.0.0",
  "description": "A comprehensive n8n community node for Gate.io cryptocurrency exchange providing 14 resources and 100+ operations for spot, margin, futures, and options trading. Includes unified account, sub-account management, earn products, and flash swap functionality.",
  "license": "BUSL-1.1",
  "author": {
    "name": "Velocity BPA",
    "email": "licensing@velobpa.com",
    "url": "https://velobpa.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Velocity-BPA/n8n-nodes-gateio.git"
  },
  "homepage": "https://github.com/Velocity-BPA/n8n-nodes-gateio#readme",
  "bugs": {
    "url": "https://github.com/Velocity-BPA/n8n-nodes-gateio/issues"
  },
  "keywords": [
    "n8n",
    "n8n-community-node-package",
    "gateio",
    "gate.io",
    "cryptocurrency",
    "crypto",
    "trading",
    "exchange",
    "spot",
    "futures",
    "margin",
    "options",
    "defi",
    "api",
    "automation"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "COMMERCIAL_LICENSE.md",
    "LICENSING_FAQ.md",
    "README.md"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/GateIoApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/GateIo/GateIo.node.js",
      "dist/nodes/GateIo/GateIoTrigger.node.js"
    ]
  },
  "scripts": {
    "build": "tsc && gulp build:icons",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^7.1.0",
    "@typescript-eslint/parser": "^7.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.1",
    "gulp": "^4.0.2",
    "jest": "^29.7.0",
    "n8n-workflow": "^1.35.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "n8n-workflow": ">=1.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
